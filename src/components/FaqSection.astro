---
export interface Faq {
  question: string;
  answer: string;
}
export interface Props {
  faqs: Faq[];
  title?: string;
}
const { faqs, title = 'Frequently asked questions' } = Astro.props;
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<section class="container pb-16">
  <div class="card">
    <p class="editorial-kicker">FAQ</p>
    <h2 class="mt-3 font-serif text-4xl font-black tracking-tight text-slate-950">{title}</h2>
    <div class="mt-10 space-y-10">
      {faqs.map((faq) => (
        <div>
          <h3 class="text-xl font-black text-slate-950">{faq.question}</h3>
          <p class="mt-4 text-[17px] leading-8 text-slate-700">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
