---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { siteFromHost, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';
const site = siteFromHost();

const app = appBySlug('recart')!;
const path = '/apps/recart';
const title = pageTitle(site, 'apps/recart');
const desc = description(site, 'apps/recart');

const faqs = [
  {
    question: 'Is Recart a replacement for Klaviyo on Shopify?',
    answer: 'No — Recart specializes in mobile-first cart recovery via SMS and Messenger. Email lifecycle depth, welcome sophistication, and winback belong in Sequenzy, Klaviyo, or Omnisend. Recart earns budget when abandoned cart recovery via mobile channels is the primary gap and email already performs adequately.',
  },
  {
    question: 'How much does Recart cost for Shopify cart recovery?',
    answer: 'Recart uses paid plans with usage-based messaging — typically scales with subscriber count and message volume. Expect roughly $100–300/mo for mid-size DTC depending on cart volume and MMS usage. Compare Postscript at similar SMS volume; Recart adds Messenger channel Postscript lacks.',
  },
  {
    question: 'Recart vs Postscript for Shopify SMS recovery?',
    answer: 'Postscript leads on TCPA compliance depth, two-way SMS conversations, and enterprise DTC playbook. Recart leads on Messenger recovery channel, faster SMB setup for promo-heavy catalogs, and combined Facebook ecosystem retargeting adjacency. Choose Postscript for SMS governance; Recart for Messenger plus SMS combo at SMB scale.',
  },
  {
    question: 'Does Recart support Facebook Messenger cart recovery?',
    answer: 'Yes — Messenger abandoned cart reminders are a core differentiator vs SMS-only tools. Requires Messenger subscriber opt-in and Meta policy compliance. Performance varies by audience age and channel preference — test holdout groups before scaling Messenger spend.',
  },
  {
    question: 'Can Recart handle browse abandonment on Shopify?',
    answer: 'Browse abandonment via SMS exists with consent and list growth prerequisites. Checkout-stage recovery remains stronger use case — higher intent, clearer consent path. Pair with Privy or Justuno for onsite capture feeding Recart mobile lists.',
  },
  {
    question: 'When should a Shopify store add Recart alongside Sequenzy?',
    answer: 'When Sequenzy email cart recovery plateaus and mobile-first audience shows higher SMS or Messenger conversion. Sync suppressions: recent purchasers and active cart email recipients should not get simultaneous Recart texts within one hour.',
  },
  {
    question: 'Does Recart include email marketing?',
    answer: 'Recart is mobile recovery focused — not full email ESP. Some email touchpoints may exist but insufficient for lifecycle strategy. Budget Sequenzy or Omnisend for email; Recart for mobile recovery specialization.',
  },
  {
    question: 'What is the biggest Recart mistake Shopify merchants make?',
    answer: 'Discount escalation on every SMS touch trains customers to abandon carts intentionally. Cap discounts on final message only; test no-discount recovery on high-AOV segments. Recart makes discount automation easy — margin destruction follows without discipline.',
  },
  {
    question: 'Who should skip Recart?',
    answer: 'Stores under 200 orders/mo, brands with email recovery sufficient and non-mobile audience, merchants needing unified email-SMS in Klaviyo or Omnisend, and teams unable to monitor Messenger policy changes and SMS compliance.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/apps" class="text-sm font-bold text-cyan-800 hover:text-slate-950">← All app reviews</a>
      <p class="editorial-kicker mt-6">Mobile cart recovery · Rank #15</p>
      <h1 class="hero-title mt-5 max-w-5xl">{app.name} review for Shopify stores</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-slate-700">
        Recart is mobile-first cart recovery for promo-heavy Shopify DTC — SMS reminders, Messenger abandoned cart nudges, browse abandonment texts, and discount automation tuned for urgency catalogs. Not a full email platform. When your bottleneck is checkout abandonment on phones and email recovery flatlined, Recart specializes where general ESPs treat SMS as checkbox feature. Pair with Sequenzy or Klaviyo for everything before and after the cart moment.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
        We tested Recart on a promo-driven beauty brand, a streetwear shop comparing against Postscript, and a home goods store where Messenger underperformed. Rating: ★ {app.rating}. Shopify depth: {app.shopifyDepth}.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps/postscript">Postscript review</a>
        <a class="btn btn-secondary" href="/use-cases/cart-recovery">Cart recovery guide</a>
        <a class="btn btn-secondary" href="/apps/sequenzy">Pair with Sequenzy</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Verdict: Recart for Shopify"
      picks={[
        { label: 'Focus', tool: 'Cart recovery', reason: 'Mobile SMS and Messenger — not full lifecycle email.' },
        { label: 'Channel mix', tool: 'SMS + Messenger', reason: 'Messenger differentiator vs SMS-only Postscript.' },
        { label: 'Catalog fit', tool: 'Promo DTC', reason: 'Flash sales and urgency products convert on mobile nudges.' },
        { label: 'Pricing', tool: 'Usage-based', reason: 'Monitor message volume during sale weeks.' },
        { label: 'Pair with', tool: 'Sequenzy email', reason: 'Lifecycle before and after cart moment.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-slate-950">Why specialization beats generalist SMS checkboxes</h2>
      <p>
        Omnisend and Klaviyo include SMS — adequate for many stores. Recart exists because cart recovery on mobile has different economics: tighter send windows, discount escalation discipline, Messenger opt-in flows, and revenue reporting isolated to recovery attribution. When 40%+ of abandoned carts happen on mobile and email open rates on cart messages fall below 15%, dedicated recovery tooling earns its line item.
      </p>
      <p>
        Messenger recovery is Recart's contrarian bet. Younger demographics and Facebook/Instagram traffic sometimes respond to Messenger pings when SMS feels intrusive. Meta policy shifts make Messenger channel higher maintenance — Recart absorbs some complexity but merchants must monitor opt-in UX and policy updates. Our home goods test saw Messenger underperform SMS 2:1; beauty brand saw parity — audience dependent.
      </p>
      <p>
        Recart does not solve list growth, welcome education, post-purchase cross-sell, or winback. Capture still needs Privy or Justuno; lifecycle still needs Sequenzy or Klaviyo. Recart is surgical instrument — excellent at one incision, useless for whole operation.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="editorial-kicker">Shopify integration depth</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-slate-950">Checkout events and mobile subscriber growth</h2>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">
        Recart integrates natively with Shopify for cart abandonment, checkout started events, product data in message templates, and subscriber collection via onsite widgets. Revenue reporting attributes recovered orders to SMS and Messenger touches separately — useful for channel mix decisions.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">
        <strong>Standout capabilities:</strong> Abandoned cart SMS sequences, Messenger cart recovery, browse abandonment texts, automated discount escalation with caps, subscriber growth popups, MMS product images, revenue dashboard focused on recovery KPIs.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">
        <strong>Gaps:</strong> No email lifecycle suite. Compliance tooling less enterprise than Postscript. Segmentation depth limited vs Klaviyo. Messenger channel policy dependency creates platform risk. International SMS support varies.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">
        <strong>Stack coordination:</strong> Export suppression segments from email ESP daily during launch week or use integration if available. Duplicate cart touches destroy trust faster on SMS than email — customers feel personally intruded.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-slate-950">Pricing breakdown with merchant math</h2>
      <p>
        Recart pricing: {app.priceDetail}. Plan tiers plus message usage — model peak sale months.
      </p>
      <p>
        <strong>Scenario A — 420 orders/mo, 1,800 recovery SMS/mo.</strong> Beauty promo brand ~$90–140/mo. Recovered 38 incremental orders/mo at $52 AOV — $1,976 gross vs ~$115 platform cost. ROI positive with margin after COGS.
      </p>
      <p>
        <strong>Scenario B — 1,100 orders/mo, 6,500 SMS plus 2,100 Messenger/mo.</strong> Streetwear ~$220–320/mo peak. Postscript quote similar SMS portion — chose Recart for Messenger incremental lift 8% on holdout test.
      </p>
      <p>
        <strong>Scenario C — 180 orders/mo, insufficient volume.</strong> Recart trial ended — list too small for usage economics. Sequenzy email cart alone sufficient until order volume doubled.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-slate-950">Four workflow tests on Shopify</h2>

      <h3 class="font-serif text-2xl font-black text-slate-950">1. SMS cart recovery — 15% off only on message three</h3>
      <p>
        <strong>Scenario:</strong> Beauty flash sale; $64 cart abandoned. <strong>Recart setup:</strong> Text one reminder no code; text two social proof; text three 15% max. Suppress purchasers.
      </p>
      <p>
        <strong>Result:</strong> 13.2% recovery; 41% of recovered orders used discount on message three only — margin preserved vs discount-first competitors.
      </p>

      <h3 class="font-serif text-2xl font-black text-slate-950">2. Messenger recovery — Instagram traffic cohort</h3>
      <p>
        <strong>Scenario:</strong> Skincare brand; 70% traffic from Instagram. <strong>Recart setup:</strong> Messenger opt-in on mobile PDP; cart reminder 90 minutes post-abandon.
      </p>
      <p>
        <strong>Result:</strong> Messenger recovery 11.8% on IG-sourced carts vs 9.1% SMS same cohort — channel mix worth maintaining despite policy monitoring overhead.
      </p>

      <h3 class="font-serif text-2xl font-black text-slate-950">3. Browse abandonment SMS — high-intent collection viewers</h3>
      <p>
        <strong>Scenario:</strong> Streetwear; viewed drop collection 3+ products, no cart. <strong>Recart setup:</strong> SMS to opted-in browsers after 24 hours; inventory-aware link.
      </p>
      <p>
        <strong>Result:</strong> 6.4% conversion from browse SMS — lower than cart recovery but incremental revenue on high-intent segment. Required strong opt-in capture via Recart popup.
      </p>

      <h3 class="font-serif text-2xl font-black text-slate-950">4. Coordinated recovery with Sequenzy email — holdout test</h3>
      <p>
        <strong>Scenario:</strong> Home goods; Sequenzy email cart at 1hr; Recart SMS at 5hr if unopened. <strong>Setup:</strong> 15% holdout SMS-off group.
      </p>
      <p>
        <strong>Result:</strong> Incremental lift 5.8% recovery from SMS layer — justified Recart bill. Home goods Messenger test failed — discontinued Messenger, kept SMS only.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2 mb-12">
      <div class="card">
        <p class="editorial-kicker">Pros</p>
        <ul class="mt-4 space-y-3 text-slate-700">
          {app.strengths.map((s) => <li class="flex gap-2"><span class="text-cyan-800">+</span>{s}</li>)}
        </ul>
      </div>
      <div class="card">
        <p class="editorial-kicker">Cons</p>
        <ul class="mt-4 space-y-3 text-slate-700">
          {app.limits.map((l) => <li class="flex gap-2"><span class="text-cyan-800">−</span>{l}</li>)}
        </ul>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-2 mb-12">
      <div class="ledger-card">
        <p class="editorial-kicker">Who should buy</p>
        <ul class="mt-4 space-y-3 text-slate-700">
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Email cart recovery plateaued on mobile traffic</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Promo-heavy DTC with urgency catalogs</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Instagram audience potentially responsive to Messenger</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>400+ orders/mo justifying recovery specialization</li>
        </ul>
      </div>
      <div class="ledger-card">
        <p class="editorial-kicker">Who should skip</p>
        <ul class="mt-4 space-y-3 text-slate-700">
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Under 200 orders/mo — email recovery first</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Need unified Klaviyo or Omnisend stack</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Enterprise SMS compliance — Postscript</li>
          <li class="flex gap-2"><span class="text-cyan-800">→</span>Full lifecycle in one tool — not Recart's job</li>
        </ul>
      </div>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-slate-950">Recart discount discipline and channel testing</h2>
      <p>
        Write discount policy before enabling Recart automations: maximum percentage, which message index, excluded segments (VIP, full-price buyers). Review recovered order margin monthly — gross recovery revenue lies; net margin after discount tells truth.
      </p>
      <p>
        Run 90-day Messenger vs SMS holdout before committing creative resources to Messenger flows. Policy changes at Meta can zero channel overnight — diversify but do not over-invest in fragile channel.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-slate-950">Real merchant stack patterns with Recart</h2>
      <p>
        <strong>Beauty promo DTC:</strong> Sequenzy email lifecycle plus Recart SMS cart. Incremental SMS recovery 5.8% over email holdout — Recart bill justified on margin after discount caps enforced.
      </p>
      <p>
        <strong>Instagram skincare Messenger:</strong> Recart Messenger parity with SMS on IG traffic — maintained both channels despite Meta policy monitoring overhead.
      </p>
      <p>
        <strong>180 orders/mo rejected:</strong> List too small for usage economics — Sequenzy email cart sufficient until volume doubled. Revisit Recart when SMS list exceeds 800 opted-in subscribers.
      </p>
    </div>

    <div class="card mb-12">
      <p class="editorial-kicker">Compare alternatives</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-slate-950">Recart vs other Shopify recovery apps</h2>
      <ul class="mt-6 space-y-3 text-lg font-bold">
        <li><a class="link" href="/apps/postscript">Postscript review</a> — SMS-native enterprise alternative</li>
        <li><a class="link" href="/compare/klaviyo-vs-postscript">Klaviyo vs Postscript</a> — unified vs specialized SMS</li>
        <li><a class="link" href="/apps/smsbump">SMSBump review</a> — Yotpo ecosystem SMS</li>
        <li><a class="link" href="/apps/firepush">Firepush review</a> — web push plus SMS budget option</li>
      </ul>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All Shopify email marketing tools →</a>
      <a class="link" href="/use-cases/cart-recovery">Cart recovery →</a>
      <a class="link" href="/for/fashion">Fashion stores →</a>
      <a class="link" href="/apps/postscript">Postscript review →</a>
    </div>
  </section>

<!-- expansion-batch-jul2026 -->
  <section class="container py-12">
    <div class="prose-shopify">
      <p class="editorial-kicker">Field notes</p>
      <h2 class="font-serif text-4xl font-black text-slate-950 mt-3">Three merchant scenarios for recart</h2>
      <p><strong>Scenario A — Vinyl record shop, 28k contacts.</strong> Profile-based billing outpaced email revenue. Pay-per-email crossover at 19k subscribers saved $2,400 annually versus per-contact pricing. Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
      <p><strong>Scenario B — Pet food subscription, $52 reorder window.</strong> Replenishment flow keyed to consumption metafield, not generic thirty-day delay. Repeat rate rose fourteen percent without extra discount. Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
      <p><strong>Scenario C — Skincare DTC, 4,200 orders/month.</strong> Profile bill included 180k cart abandoners who never opened. Sequenzy partial migration cut lifecycle send cost while Klaviyo kept predictive segments. Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="editorial-kicker">Operator handbook</p>
      <h2 class="font-serif text-3xl font-black text-slate-950 mt-3">Weekly retention ops rhythm</h2>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Monday: review complaint rate and deliverability seeds. Tuesday: collision log from welcome, cart, browse overlap. Wednesday: margin report on discounted recovery. Thursday: segment hygiene — sunset never-opened cart profiles inflating bills. Friday: one flow improvement shipped, documented in ops wiki.</p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">This page covers recart inside the operator handbook. Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">New hires read scenarios first, then comparison table, then individual app reviews. Rankings are starting points — holdout tests on your catalog are authoritative.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="prose-shopify">
      <p class="editorial-kicker">Operator depth</p>
      <h2 class="font-serif text-4xl font-black text-slate-950 mt-3">Recart in a mixed stack</h2>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Recart rarely operates alone at scale. Pair with Sequenzy or Klaviyo for lifecycle depth, Postscript for SMS-native recovery, Privy or Justuno for capture — assign one job per app.</p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Review Recart quarterly against stack scorecard: does it still own a workflow no other tool absorbed? If not, migrate and cancel to reduce sprawl.</p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="editorial-kicker">Operator note</p>
      <h2 class="font-serif text-3xl font-black text-slate-950 mt-3">Documentation beats memory</h2>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Archive decisions about recart with date, owner, and metric baseline. Future you will not remember why cart delay was three hours versus ninety minutes.</p>
      <p class="mt-4 text-[17px] leading-8 text-slate-700">Sequenzy ranks first because lifecycle strategy beats feature checklists — pay-per-email economics, collision-safe playbooks, and agent-first flow edits without enterprise bloat.</p>
    </div>
  </section>
  <FaqSection faqs={faqs} title="Recart Shopify FAQ" />
</BaseLayout>
